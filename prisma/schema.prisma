generator client {
  provider = "prisma-client-js" // Tells Prisma to generate a JS/TS client, This client is what you use in NestJS to query DB
}

datasource db {
  provider = "postgresql" // Database provider - PostgreSQL
  url      = env("DATABASE_URL") // Database URL - Your DB connection string
}

model User {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String    @unique
  gender     String?
  dob        DateTime?
  phone      String?
  occupation String?
  password   String
  tasks      Task[]
}

model Task {
  id        Int     @id @default(autoincrement())
  title     String
  completed Boolean @default(false)
  userId    Int // this is the foreign key
  user      User    @relation(fields: [userId], references: [id]) // this connects Task.userId → User.id
}
