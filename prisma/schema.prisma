generator client {
  provider = "prisma-client-js" // Tells Prisma to generate a JS/TS client, This client is what you use in NestJS to query DB
}

datasource db {
  provider = "postgresql" // Database provider - PostgreSQL
  url      = env("DATABASE_URL") // Database URL - Your DB connection string
}

model User {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String    @unique
  gender     String?
  dob        DateTime?
  phone      String?
  occupation String?
  password   String?
  googleId   String?  @unique
  createdAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  tasks      Task[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  priority    Priority
  status      Status
  userId      Int // this is the foreign key
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id]) // this connects Task.userId → User.id

  @@index([userId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  COMPLETED
}