generator client {
  provider = "prisma-client-js" // Tells Prisma to generate a JS/TS client, This client is what you use in NestJS to query DB
}

datasource db {
  provider  = "postgresql" // Database provider - PostgreSQL
  url       = env("DATABASE_URL") // Database URL - Your DB connection string
  directUrl = env("DIRECT_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String    @unique
  gender     String?
  dob        DateTime?
  phone      String?
  occupation String?
  password   String?
  googleId             String?   @unique
  picture              String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  tasks      Task[]
  pushSubscriptions PushSubscription[]
  settings   UserSetting?
}

model UserSetting {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  theme           String   @default("light")
  language        String   @default("en")
  timezone        String   @default("Asia/Kolkata")
  dateFormat      String   @default("EEE, dd MMM yyyy")
  sidebarState    String   @default("expanded")
  extraSettings   Json     @default("{}")
  user            User     @relation(fields: [userId], references: [id])
  updatedAt       DateTime @updatedAt
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  priority    Priority
  status      Status
  userId      Int // this is the foreign key
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id]) // this connects Task.userId → User.id

  @@index([userId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  COMPLETED
  PENDING
}